# Firebase web config (client-side; not secrets)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Google Sign-In (Expo Auth Session)
GOOGLE_EXPO_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Ads (AdMob) - note: requires custom dev client/EAS build for full support
ADS_ENABLED=0
ADMOB_APP_ID=
ADMOB_BANNER_ID=
ADMOB_INTERSTITIAL_ID=

# Payments
STRIPE_PROVIDER=stripe
STRIPE_PUBLISHABLE_KEY=
PAYMENTS_UPI_ENABLED=0

# Razorpay fallback (optional)
RAZORPAY_KEY_ID=

# Cloud Functions
FUNCTIONS_REGION=us-central1
